# =============================================================================
# terraform.tfvars.example
# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is in .gitignore — NEVER commit it.
# =============================================================================

# --- Azure identity ----------------------------------------------------------
subscription_id = "00000000-0000-0000-0000-000000000000" # az account show --query id
tenant_id       = "00000000-0000-0000-0000-000000000000" # az account show --query tenantId

# --- Resource placement ------------------------------------------------------
resource_group_name = "rg-ecomm"
location            = "eastus"    # change to e.g. westeurope if preferred
environment         = "dev"

# --- Key Vault ---------------------------------------------------------------
# Must be globally unique across all Azure. 3-24 chars, alphanumeric + hyphens.
key_vault_name = "kv-ecomm-unique123"

# --- Virtual Machine ---------------------------------------------------------
vm_size           = "Standard_B2s"
vm_admin_username = "ecommadmin"
vm_admin_password = "REPLACE_WITH_STRONG_PASSWORD" # SECRET — do not commit real values

# Paste the contents of your deploy_key.pub file (generated with ssh-keygen -t ed25519)
# The key below was generated by running: ssh-keygen -t ed25519 -f deploy_key -C "ecomm-cicd-deploy"
# Replace with your own key if you regenerate the keypair.
vm_ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIKzh9BrNhS7Qv7j6+EqmdZjJVOBUpkwNs3MRPWibfLSf ecomm-cicd-deploy"

# --- Networking --------------------------------------------------------------
# Your current public IP in CIDR notation. Find it with: curl ifconfig.me
# The /32 suffix restricts access to exactly one IP address.
allowed_rdp_source_ip = "203.0.113.10/32" # REPLACE with your actual IP
allowed_ssh_source_ip = "203.0.113.10/32" # REPLACE with your actual IP (can be same as RDP)

# --- Database secrets --------------------------------------------------------
mysql_root_password = "REPLACE_WITH_STRONG_ROOT_PASSWORD" # SECRET — do not commit real values
db_password         = "REPLACE_WITH_STRONG_APP_PASSWORD"  # SECRET — do not commit real values
