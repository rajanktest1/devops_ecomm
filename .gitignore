# ============================================================
# Dependencies
# ============================================================
node_modules/
jspm_packages/
bower_components/

# ============================================================
# Build outputs
# ============================================================
frontend/dist/
frontend/build/
frontend/.vite/
backend/dist/
backend/build/

# ============================================================
# Environment variables — NEVER commit real secrets
# ============================================================
# Catch .env anywhere in the repo (top-level or nested)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.*.local
# Explicit subdirectory paths (belt-and-suspenders)
frontend/.env
frontend/.env.local
frontend/.env.*.local
backend/.env
backend/.env.local
backend/.env.*.local
# Common secret file patterns
*.pem
*.key
# SSH deploy key pair — NEVER commit the private key
deploy_key
# deploy_key.pub is safe to commit but excluded to avoid accidental exposure
deploy_key.pub
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_ed25519
*.secret

# ============================================================
# Logs
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

azure-cicd-pipeline.prompt.md
azure-cicd-pipeline.prompt
# ============================================================
# Runtime & temp files
# ============================================================
pids/
*.pid
*.seed
*.pid.lock
tmp/
temp/

# ============================================================
# OS noise
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
desktop.ini
$RECYCLE.BIN/

# ============================================================
# Editor / IDE noise
# ============================================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.project
.classpath
.settings/
nbproject/
*.iml
.history/

# ============================================================
# Test / coverage output
# ============================================================
coverage/
.nyc_output/
.jest-cache/

# ============================================================
# Package manager lock-file alternatives (keep only what you use)
# ============================================================
# Uncomment whichever you are NOT using:
# yarn.lock
# pnpm-lock.yaml

